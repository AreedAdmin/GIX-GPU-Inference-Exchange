{
  "name": "@gix/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GIX consumer SDK — turns an inference request into an on-chain compute purchase (create_job + MOCK_USDC escrow) served by a provider GPU, with verifiable output.",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mysten/deepbook-v3": "^1.5.1",
    "@mysten/sui": "^2.19.0",
    "@mysten/walrus": "^1.2.1",
    "@mysten/walrus-wasm": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
