# GIX web — runtime config (all optional; app defaults to MockDataSource)
# Set to "ws" to use the live WS feed (web/src/data/ws.ts, provided by Agent B).
VITE_DATA_SOURCE=mock

# WS endpoint exposed by `npm run stream -- --serve` (harness, Agent B)
VITE_WS_URL=ws://127.0.0.1:8787

# Sui localnet endpoints (used by Agent C's OrderClient / tx layer)
VITE_RPC_URL=http://127.0.0.1:9000
VITE_FAUCET_URL=http://127.0.0.1:9123

# ── Real on-chain buy + wallet + result viewer (demo-milestone-contract §5/§6) ──
# "sui" wires the real OrderClient (burner key + create_job + /result verify).
# Leave as "mock" for the offline demo (no chain/provider needed).
VITE_ORDER_CLIENT=mock
# Network drives faucet + explorer derivation. localnet = burner; testnet = wallet-connect.
VITE_NETWORK=localnet
# Provider node serving POST /inputs, GET /result/:jobId, GET /health (node §3.1).
VITE_PROVIDER_URL=http://127.0.0.1:8080
# Provider operator address that fills the stubbed match (holds ProviderStake + Credit<M>).
# Defaults to deployment.json providers[0].
# VITE_PROVIDER_ADDRESS=0xb8e7af9d7be92710d38b1f867c6bc99db9171e47d7bc1afef87ba8a4350ee4e7

# deployment.json values — default to the bundled localnet ids; override on testnet redeploy.
# VITE_PACKAGE_ID=0x...
# VITE_CONFIG_ID=0x...
# VITE_USDC_TYPE=0x...::mock_usdc::MOCK_USDC
# VITE_FAUCET_ID=0x...
# VITE_MARKET_ID=0x...
# VITE_MARKET_CREDIT_TYPE=0x...::markets::M_H100_LLAMA8B
# VITE_MARKET_MODEL_ID=0x...
# VITE_EXPLORER_TX_BASE=https://suiscan.xyz/testnet/tx
